# Secrets and dependencies
.env
node_modules/

# Generated per-campaign output (see CLAUDE.md > Git tracking)
/pipeline/

# Per-recipient research (campaign input; contains personal data and delivery
# addresses — keep out of git so it is never pushed to a remote).
research/

# Chain runner: generated per-piece output is not tracked. runner/config.json IS
# tracked so a fresh session always has the sender profile. Keep it secret-free:
# no API keys or tokens (the runner authenticates via the logged-in Claude CLI).
runner/pieces/
__pycache__/
*.pyc

# Print-ready deliverables are NOT committed to code branches. Lossless PNGs and
# companion cards live on the orphan `deliverables` branch only (one stable home
# for the print supplier, code branches stay free of large binaries). Use
# deliverables/ purely as a local staging area before pushing to that branch.
deliverables/

# Birch shipping CSVs and staged print folders contain delivery addresses.
# Never commit them (same reason research/ is ignored).
*-birch.csv
birch-*/

# Newspaper engine render output (generated artefacts, kept out of git).
# The blank template (newspaper_template_a2.png) IS tracked; rendered pages
# and scratch previews are not.
newspaper/_*.png
newspaper/*_final*.png
newspaper/*_print*.png
newspaper/mmc_*.png

# P7b validation output (generated per run; comparisons of real replies stay local)
runner/reply_validation/out/
