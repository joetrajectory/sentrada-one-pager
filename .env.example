# Copy to .env and fill in. .env is gitignored; nothing here may be committed.

# Address capture: must match RUNNER_SECRET on the Vercel deployment. Used by
# tease/capture/address/delivered to talk to the site's /api/runner function.
SENTRADA_RUNNER_SECRET=

# Chain runner: none required (model calls run through the logged-in Claude
# CLI on a subscription).

# Optional
ANTHROPIC_API_KEY=        # only if runner/config.json sets "vision_backend": "sdk"
IMAGE_GEN_API_KEY=        # image-gen formats only (Claymation, parked)

# MCP connections
NOTION_MCP_TOKEN=         # Notion integration token (campaign log, research outputs)
APOLLO_API_KEY=           # Apollo.io API key (contact data, company signals)

# Sourcing pipeline (sourcing/)
FULLENRICH_API_KEY=       # FullEnrich; enrich runs on approved names only, stub without it
COMPANIES_HOUSE_API_KEY=  # optional; desk-check registered-office lookups
ADZUNA_APP_ID=            # abm-hiring scrape path (free at developer.adzuna.com)
ADZUNA_APP_KEY=           # paste path works without these

# Future (not required yet)
PRINT_SUPPLIER_API_KEY=   # Print-on-demand supplier API
SHIPPING_API_KEY=         # Shipping/tracking API
HUBSPOT_API_KEY=          # For triggering follow-up sequences in client's outbound tool
